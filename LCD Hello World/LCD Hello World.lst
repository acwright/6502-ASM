000000r 2               LCD_E               := %10000000    ; PORTA LCD ENABLE
000000r 2               LCD_RW              := %01000000    ; PORTA LCD R/W
000000r 2               LCD_RS              := %00100000    ; PORTA LCD REGISTER SELECT
