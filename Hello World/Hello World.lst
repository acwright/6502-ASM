000000r 1               .segment "CODE"
000000r 1               
000000r 1               CHROUT := $0000       ; TODO: This needs to be updated with actual CHROUT location!
000000r 1               
000000r 1               Start:
000000r 1  A9 0D          lda #$0D            ; Carriage Return
000002r 1  20 00 00       jsr CHROUT          ; Write char to output device
000005r 1  A9 0A          lda #$0A            ; Line feed
000007r 1  20 00 00       jsr CHROUT          ; Write char to output device
00000Ar 1               
00000Ar 1  A2 00          ldx #0
00000Cr 1               Print:
00000Cr 1  BD rr rr       lda message,x
00000Fr 1  F0 07          beq @PrintEnd
000011r 1  20 00 00       jsr CHROUT          ; Write char to output device
000014r 1  E8             inx
000015r 1  4C rr rr       jmp Print
000018r 1               @PrintEnd:
000018r 1  A9 0D          lda #$0D            ; Carriage Return
00001Ar 1  20 00 00       jsr CHROUT          ; Write char to output device
00001Dr 1  A9 0A          lda #$0A            ; Line feed
00001Fr 1  20 00 00       jsr CHROUT          ; Write char to output device
000022r 1               
000022r 1               Break:
000022r 1  00             brk                 ; Break back to monitor
000023r 1               
000023r 1  48 65 6C 6C  message: .asciiz "Hello, World!"
